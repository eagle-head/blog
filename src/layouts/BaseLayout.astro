---
// src/layouts/BaseLayout.astro
// Brief §6.1, §6.2, §7.2 — Page shell: <html lang>, theme-init script
// before first paint, <SEO /> slot, Header + content slot + Footer.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPaletteHost from '../components/CommandPaletteHost';
import Analytics from '../components/Analytics.astro';
import { themeInitScript } from '../lib/theme-init';

interface Props {
  lang?: 'en' | 'pt-BR';
}
const { lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
    {/* Bing Webmaster Tools domain ownership verification (Plan 07 Phase 2). */}
    <meta name="msvalidate.01" content="99C11D4FD95F4A84076A1D2354311281" />
    {/* Preload the primary font subsets so they arrive before first paint. */}
    {/* Hash filenames are stable across builds unless @fontsource-variable is bumped. */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/_astro/jetbrains-mono-latin-wght-normal.B9CIFXIH.woff2"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {/* RSS feed discovery — locale-scoped so feed readers pick the user-facing language. */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Eduardo Kohn — All"
      href={lang === 'pt-BR' ? '/pt-br/rss.xml' : '/rss.xml'}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Eduardo Kohn — Papers"
      href={lang === 'pt-BR' ? '/pt-br/papers.rss.xml' : '/papers.rss.xml'}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Eduardo Kohn — Posts"
      href={lang === 'pt-BR' ? '/pt-br/posts.rss.xml' : '/posts.rss.xml'}
    />
    <script is:inline set:html={themeInitScript} />
    <slot name="head" />
    <Analytics />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CommandPaletteHost client:idle locale={lang} />
  </body>
</html>
