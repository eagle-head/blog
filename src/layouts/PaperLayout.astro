---
// src/layouts/PaperLayout.astro
// Brief §6.4 — paper layout. Single centered reading column (the Tufte side
// rail was dropped — no paper used <Sidenote> — so the column now centers
// instead of leaning left). Below 1024px the article is replaced by a notice.
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import MetaChip from '../components/MetaChip.astro';
import Tag from '../components/Tag.astro';
import SEO from '../components/SEO.astro';
import Giscus from '../components/Giscus.astro';
import { parseEntryId } from '../lib/content';
import { formatDateForLocale } from '../lib/i18n';
import { ogImagePathFor } from '../lib/og';
import { t } from '../lib/ui';

interface Props {
  entry: CollectionEntry<'papers'>;
  /** Canonical EN path, e.g. "/papers/quicksort". */
  canonicalPath: string;
  /** Rendered reading time string, e.g. "12 min". */
  readingTime: string;
}
const { entry, canonicalPath, readingTime } = Astro.props;
const { title, abstract, publishedAt, updatedAt, authors, tags, keywords, doi, language, comments } = entry.data;
const { slug } = parseEntryId(entry.id);

const chipText = `${t(language, 'kind.paper')} · ${formatDateForLocale(publishedAt, language)} · ${readingTime}`;
const authorLine = authors.map((a) => (a.affiliation ? `${a.name} · ${a.affiliation}` : a.name)).join(', ');
---

<BaseLayout lang={language}>
  <SEO
    slot="head"
    title={`${title} — Eduardo Kohn`}
    description={abstract}
    canonicalPath={canonicalPath}
    ogImage={ogImagePathFor('paper', slug, language)}
    jsonLd={{
      kind: 'paper',
      title,
      abstract,
      publishedAt,
      updatedAt,
      keywords,
      doi,
      authors,
      inLanguage: language,
    }}
  />

  <article class="paper" data-pagefind-body>
    {/* Pagefind filters — one element per filter; combined via search({ filters: {...} }). */}
    <span hidden data-pagefind-filter="kind:paper"></span>
    <span hidden data-pagefind-filter={`lang:${language}`}></span>
    <MetaChip text={chipText} />
    <h1 class="paper-title">{title}</h1>
    <p class="paper-author">{authorLine}</p>
    <div class="paper-tags">
      {tags.map((t) => <Tag name={t} href={`/tags/${t}`} />)}
    </div>
    <div class="paper-abstract">
      <b>Abstract.</b>
      {' '}
      {abstract}
    </div>
    <div class="paper-body">
      <slot />
    </div>
    {comments && <Giscus lang={language} />}
  </article>

  {
    /* Below 1024px the paper's wide diagrams and terminal output are illegible,
      so the article is hidden and this notice replaces it. Localised at build
      time — each paper page is per-locale. Widening the window past 1024px
      reveals the article instantly, no reload. */
  }
  <section class="paper-narrow-notice" role="note" aria-label={t(language, 'viewport.narrow.title')}>
    <p class="pnn-num">1024<span>px</span></p>
    <p class="pnn-title">{t(language, 'viewport.narrow.title')}</p>
    <p class="pnn-body">{t(language, 'viewport.narrow.body')}</p>
    <p class="pnn-actions">
      <a href={language === 'pt-BR' ? '/pt-br/papers' : '/papers'}>{t(language, 'nav.papers')}</a>
    </p>
  </section>
</BaseLayout>

<style>
  /* Single centered reading column. The Tufte side rail was removed: no paper
     used <Sidenote>, so the rail was always empty and only pushed the text
     off-centre. */
  .paper {
    max-width: var(--measure-paper);
    margin: 0 auto;
    padding: var(--space-6) var(--space-8);
  }
  .paper-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin: var(--space-2) 0 var(--space-2) 0;
    color: var(--color-fg);
  }
  .paper-author {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0 0 var(--space-3) 0;
  }
  .paper-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .paper-abstract {
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--color-text);
    padding: var(--space-3) var(--space-4);
    background: var(--color-abstract-bg);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-5);
  }
  .paper-abstract b {
    color: var(--color-fg);
  }
  /* Narrow-screen gate (< 1024px): hide the article, show the notice.
     Mirrors the 404 page's centered treatment. */
  .paper-narrow-notice {
    display: none;
  }
  .pnn-num {
    font-size: clamp(3rem, 14vw, 5rem);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-accent);
    margin: 0 0 var(--space-3) 0;
  }
  .pnn-num span {
    font-size: 0.4em;
    font-weight: var(--font-weight-bold);
    margin-left: 2px;
  }
  .pnn-title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-fg);
    margin: 0 0 var(--space-3) 0;
  }
  .pnn-body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-muted);
    margin: 0 0 var(--space-5) 0;
  }
  .pnn-actions {
    font-size: var(--text-base);
    margin: 0;
  }
  @media (max-width: 1023.98px) {
    .paper {
      display: none;
    }
    .paper-narrow-notice {
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: var(--measure-hero);
      margin: 0 auto;
      padding: var(--space-8);
      min-height: 72vh;
      text-align: center;
    }
  }
</style>
