---
// src/layouts/PostLayout.astro
// Brief §6.5 — Classic Centered single-column layout for posts.
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import MetaChip from '../components/MetaChip.astro';
import Tag from '../components/Tag.astro';
import SEO from '../components/SEO.astro';
import Giscus from '../components/Giscus.astro';
import NarrowScreenNotice from '../components/NarrowScreenNotice.astro';
import { parseEntryId } from '../lib/content';
import { formatDateForLocale } from '../lib/i18n';
import { ogImagePathFor } from '../lib/og';
import { t } from '../lib/ui';

interface Props {
  entry: CollectionEntry<'posts'>;
  canonicalPath: string;
  readingTime: string;
}
const { entry, canonicalPath, readingTime } = Astro.props;
const { title, lead, publishedAt, updatedAt, tags, language, comments } = entry.data;
const { slug } = parseEntryId(entry.id);

const chipText = `${t(language, 'kind.post')} · ${formatDateForLocale(publishedAt, language)} · ${readingTime}`;
---

<BaseLayout lang={language}>
  <SEO
    slot="head"
    title={`${title} — Eduardo Kohn`}
    description={lead}
    canonicalPath={canonicalPath}
    ogImage={ogImagePathFor('post', slug, language)}
    jsonLd={{
      kind: 'post',
      title,
      lead,
      publishedAt,
      updatedAt,
      tags,
      inLanguage: language,
    }}
  />

  <article class="post" data-pagefind-body>
    {/* Pagefind filters — one element per filter; combined via search({ filters: {...} }). */}
    <span hidden data-pagefind-filter="kind:post"></span>
    <span hidden data-pagefind-filter={`lang:${language}`}></span>
    <MetaChip text={chipText} />
    <h1 class="post-title">{title}</h1>
    <p class="post-lead">{lead}</p>
    <div class="post-tags">
      {tags.map((t) => <Tag name={t} href={`/tags/${t}`} />)}
    </div>
    <div class="post-body">
      <slot />
    </div>
    {comments && <Giscus lang={language} />}
  </article>

  {
    /* Below 1024px posts are gated like papers: the article (hidden by the gate
      below) is replaced by this notice. Localised at build time per-locale. */
  }
  <NarrowScreenNotice
    title={t(language, 'viewport.narrow.post.title')}
    body={t(language, 'viewport.narrow.post.body')}
    actionHref={language === 'pt-BR' ? '/pt-br/posts' : '/posts'}
    actionLabel={t(language, 'nav.posts')}
    ariaLabel={t(language, 'viewport.narrow.post.title')}
  />
</BaseLayout>

<style>
  .post {
    max-width: var(--measure-prose);
    margin: 0 auto;
    padding: var(--space-6) var(--gutter);
  }
  .post-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin: var(--space-2) 0 var(--space-2) 0;
    color: var(--color-fg);
  }
  .post-lead {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0 0 var(--space-3) 0;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  /* Narrow-screen gate (< 1024px): hide the article. NarrowScreenNotice shows
     its own replacement notice at the same breakpoint. */
  @media (max-width: 1023.98px) {
    .post {
      display: none;
    }
  }
</style>
