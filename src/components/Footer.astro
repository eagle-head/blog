---
// src/components/Footer.astro
// Brief §6.2 — Site footer. RSS and newsletter links resolve to the current locale.
import { detectLocaleFromPath, localePrefix } from '../lib/i18n';

const year = new Date().getFullYear();
const locale = detectLocaleFromPath(Astro.url.pathname);
const prefix = localePrefix(locale);
const rssHref = `${prefix}/rss.xml`;
const newsletterHref = `${prefix}/newsletter`;
---

<footer class="site-footer">
  <span>© {year} Eduardo Kohn</span>
  <span class="links">
    <a href={rssHref}>RSS</a>
    <span class="sep">·</span>
    <a href={newsletterHref}>Newsletter</a>
    <span class="sep">·</span>
    <a href="https://github.com/eagle-head" target="_blank" rel="me noopener noreferrer">GitHub</a>
    <span class="sep">·</span>
    <a href="https://www.linkedin.com/in/eduardokohn84" target="_blank" rel="me noopener noreferrer">LinkedIn</a>
  </span>
</footer>

<style>
  .site-footer {
    padding-block: 20px;
    padding-inline: max(var(--gutter), env(safe-area-inset-left)) max(var(--gutter), env(safe-area-inset-right));
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    justify-content: space-between;
    align-items: center;
  }
  @media (max-width: 30rem) {
    .site-footer {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
  .site-footer a {
    color: inherit;
    text-decoration: none;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: color var(--duration-base) var(--ease-standard);
  }
  .site-footer a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  @media (hover: hover) and (pointer: fine) {
    .site-footer a:hover {
      color: var(--color-fg);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  }
  .site-footer a:active {
    color: var(--color-fg);
  }
  .links {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
  .sep {
    opacity: 0.5;
  }
</style>
