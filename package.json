    "@fontsource/inter": "^4.5.15",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "markdownlint-cli2": "^0.22.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
