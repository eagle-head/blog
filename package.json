    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "astro-pagefind": "^1.8.6",
    "astro-seo": "^1.1.0",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "pagefind": "^1.5.2",
    "preact": "^10.29.1",
    "rehype-autolink-headings": "^7.1.0",
