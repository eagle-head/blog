---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';

const LOCALE = 'en' as const;
---

<BaseLayout lang={LOCALE}>
  <SEO
    slot="head"
    title="404 — Page not found — Eduardo Kohn"
    description="The page you are looking for does not exist or has moved."
    canonicalPath="/404"
    jsonLd={{ kind: 'about' }}
  />
  <article class="u-container error-page">
    <p class="error-code">404</p>
    <h1 class="error-title">Page not found</h1>
    <p class="error-lead">The page you are looking for does not exist or has moved.</p>
    <p class="error-actions">
      <a href="/">Back to home</a>
    </p>
  </article>
</BaseLayout>

<style>
  .error-page {
    --measure: var(--measure-hero);
    padding-block: var(--space-8);
    text-align: center;
    /* Center vertically but biased a little above the true middle. */
    min-height: 72vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .error-code {
    /* Oversized display number, responsive so it never overflows on mobile
       nor balloons on huge screens. */
    font-size: clamp(4rem, 15vw, 9rem);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-accent);
    margin: 0 0 var(--space-2) 0;
  }
  .error-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-fg);
    margin: 0 0 var(--space-4) 0;
  }
  .error-lead {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-muted);
    margin: 0 0 var(--space-6) 0;
  }
  .error-actions {
    font-size: var(--text-base);
    margin: 0;
  }
</style>
