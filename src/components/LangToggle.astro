---
// src/components/LangToggle.astro
// Segmented pill showing both locales with the current one highlighted.
// Clicking the inactive segment switches while preserving the current route.
import { alternateUrls, detectLocaleFromPath } from '../lib/i18n';
import { t } from '../lib/ui';

const path = Astro.url.pathname;
const currentLocale = detectLocaleFromPath(path);
const alts = alternateUrls(path);

const isEn = currentLocale === 'en';
const isPt = currentLocale === 'pt-BR';

const titleEn = t(currentLocale, 'lang.toggle.label.to-en');
const titlePt = t(currentLocale, 'lang.toggle.label.to-pt');
---

<div class="lang-pill" role="group" aria-label="Language">
  {
    isEn ? (
      <span class="segment segment-active" aria-current="page">
        <svg class="flag" viewBox="0 0 24 16" aria-hidden="true" focusable="false">
          <rect width="24" height="16" fill="#b22234" />
          <rect y="2" width="24" height="2" fill="white" />
          <rect y="6" width="24" height="2" fill="white" />
          <rect y="10" width="24" height="2" fill="white" />
          <rect y="14" width="24" height="2" fill="white" />
          <rect width="10" height="8" fill="#3c3b6e" />
        </svg>
        <span class="label">EN</span>
      </span>
    ) : (
      <a class="segment" href={alts.en} aria-label={titleEn}>
        <svg class="flag" viewBox="0 0 24 16" aria-hidden="true" focusable="false">
          <rect width="24" height="16" fill="#b22234" />
          <rect y="2" width="24" height="2" fill="white" />
          <rect y="6" width="24" height="2" fill="white" />
          <rect y="10" width="24" height="2" fill="white" />
          <rect y="14" width="24" height="2" fill="white" />
          <rect width="10" height="8" fill="#3c3b6e" />
        </svg>
        <span class="label">EN</span>
      </a>
    )
  }

  {
    isPt ? (
      <span class="segment segment-active" aria-current="page">
        <svg class="flag" viewBox="0 0 24 16" aria-hidden="true" focusable="false">
          <rect width="24" height="16" fill="#009c3b" />
          <polygon points="12,2 22,8 12,14 2,8" fill="#ffdf00" />
          <circle cx="12" cy="8" r="3" fill="#002776" />
        </svg>
        <span class="label">PT</span>
      </span>
    ) : (
      <a class="segment" href={alts['pt-BR']} aria-label={titlePt}>
        <svg class="flag" viewBox="0 0 24 16" aria-hidden="true" focusable="false">
          <rect width="24" height="16" fill="#009c3b" />
          <polygon points="12,2 22,8 12,14 2,8" fill="#ffdf00" />
          <circle cx="12" cy="8" r="3" fill="#002776" />
        </svg>
        <span class="label">PT</span>
      </a>
    )
  }
</div>

<style>
  .lang-pill {
    display: inline-flex;
    align-items: stretch;
    height: 34px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    contain: layout;
    flex: 0 0 auto;
  }
  .segment {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 10px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    letter-spacing: 0.04em;
    line-height: 1;
    background: transparent;
    cursor: pointer;
  }
  .segment:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }
  a.segment:hover {
    background: var(--color-kbd-bg);
    color: var(--color-fg);
  }
  a.segment:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .segment-active {
    background: var(--color-abstract-bg);
    color: var(--color-fg);
    cursor: default;
  }
  .label {
    display: inline-block;
  }
  .flag {
    display: block;
    flex: 0 0 auto;
    width: 20px;
    height: 14px;
    border-radius: 2px;
    overflow: hidden;
  }
</style>
