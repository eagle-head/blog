---
// src/components/Header.astro
// Brief §6.1 — Site header: logo + nav + search bar + language/theme toggles.
// Desktop: logo, inline nav, then a search pill + language pill + theme toggle.
// Mobile (<48rem): the nav links AND the language toggle collapse into a
// hamburger menu; only three 44px icon buttons (search, theme, menu) stay in
// the bar. The menu is a native progressive-enhancement disclosure — with JS
// disabled the nav stays inline and reachable (the header wraps).
import Kbd from './Kbd.astro';
import LangToggle from './LangToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <a class="logo" href="/">Eduardo Kohn</a>

  <nav class="site-nav" id="primary-nav" aria-label="Primary">
    <a href="/papers">Papers</a>
    <a href="/posts">Posts</a>
    <a href="/about">About</a>
    <div class="nav-lang"><LangToggle /></div>
  </nav>

  <div class="site-actions">
    <button id="cmdk-trigger" type="button" class="search-trigger" aria-label="Search posts and papers (Ctrl + K)" title="Search posts and papers (Ctrl + K)">
      <svg
        class="search-icon"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <span class="search-placeholder">Search&hellip;</span>
      <Kbd>⌘K</Kbd>
    </button>
    <div class="actions-lang"><LangToggle /></div>
    <ThemeToggle />
    <button class="nav-toggle" type="button" aria-label="Menu" aria-controls="primary-nav" aria-expanded="false">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<script>
  // Progressive enhancement: with JS the nav collapses into the .nav-toggle
  // disclosure below 48rem. Without JS, .has-js is never added, so the nav
  // stays in flow (the header flex-wraps) and every link remains reachable.
  const header = document.querySelector('.site-header') as HTMLElement | null;
  const toggle = header?.querySelector('.nav-toggle') as HTMLElement | null | undefined;
  const nav = header?.querySelector('.site-nav') as HTMLElement | null | undefined;
  if (header && toggle && nav) {
    header.classList.add('has-js');
    // iOS only renders :active press feedback when the element has a touch
    // handler; attach a no-op so the press states fire on iPhone.
    [toggle, nav].forEach((el) =>
      el.addEventListener('touchstart', () => {}, { passive: true })
    );
    const close = () => {
      header.removeAttribute('data-nav-open');
      toggle.setAttribute('aria-expanded', 'false');
    };
    const open = () => {
      header.setAttribute('data-nav-open', '');
      toggle.setAttribute('aria-expanded', 'true');
    };
    toggle.addEventListener('click', () => {
      if (header.hasAttribute('data-nav-open')) close();
      else open();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.hasAttribute('data-nav-open')) {
        close();
        toggle.focus();
      }
    });
    document.addEventListener('click', (e) => {
      if (header.hasAttribute('data-nav-open') && !header.contains(e.target as Node)) {
        const focusInNav = nav.contains(document.activeElement);
        close();
        if (focusInNav) toggle.focus();
      }
    });
    nav.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) close();
    });
  }
</script>

<style>
  .site-header {
    position: relative;
    padding-block: 14px;
    padding-inline: max(var(--gutter), env(safe-area-inset-left)) max(var(--gutter), env(safe-area-inset-right));
    display: flex;
    align-items: center;
    gap: var(--space-6);
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--color-border);
  }
  .logo {
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--tracking-snug);
    font-size: var(--text-base);
    color: var(--color-fg);
    text-decoration: none;
    flex: 0 0 auto;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    color: var(--color-muted);
    flex: 0 0 auto;
  }
  .site-nav > a {
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-md);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    user-select: none;
    /* base owns the RELEASE transition (runs when :active is removed) */
    transition:
      color var(--duration-base) var(--ease-standard),
      background-color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }
  .site-nav > a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  @media (hover: hover) and (pointer: fine) {
    .site-nav > a:hover {
      color: var(--color-fg);
    }
  }
  /* press: fast, all inputs; AFTER the gated :hover so it wins source-order */
  .site-nav > a:active {
    color: var(--color-fg);
    background-color: var(--color-kbd-bg);
    transform: translateY(1px);
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav > a:active {
      transform: none; /* keep the tint, drop the motion */
    }
  }
  /* Language toggle has two homes: the actions bar (desktop) and the menu
     (mobile). Only one is ever displayed, so only one is in the a11y tree. */
  .nav-lang {
    display: none;
  }
  .actions-lang {
    display: flex;
    align-items: center;
  }

  .site-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 0 0 auto;
    margin-inline-start: auto;
  }

  /* Search-bar trigger — desktop pseudo-input; the palette is wired elsewhere. */
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 240px;
    padding: 6px 10px 6px 12px;
    background: var(--color-kbd-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-family: inherit;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      background-color var(--duration-base) var(--ease-standard),
      border-color var(--duration-base) var(--ease-standard),
      color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }
  @media (hover: hover) and (pointer: fine) {
    .search-trigger:hover {
      background: var(--color-bg);
      border-color: var(--color-muted);
      color: var(--color-fg);
    }
  }
  .search-trigger:active {
    transform: translateY(1px);
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }
  @media (prefers-reduced-motion: reduce) {
    .search-trigger:active {
      transform: none;
    }
  }
  .search-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .search-icon {
    flex: 0 0 auto;
    color: var(--color-muted);
  }
  .search-placeholder {
    flex: 1 1 auto;
    text-align: left;
  }

  /* Hamburger — hidden on desktop; shown only when JS collapses the nav. */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    min-block-size: 44px;
    min-inline-size: 44px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: var(--radius-md);
    color: var(--color-muted);
    cursor: pointer;
    flex: 0 0 auto;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    user-select: none;
    transition:
      color var(--duration-base) var(--ease-standard),
      background-color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }
  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  @media (hover: hover) and (pointer: fine) {
    .nav-toggle:hover {
      color: var(--color-fg);
      background-color: var(--color-kbd-bg);
    }
  }
  /* press: fast, all inputs; AFTER the gated :hover (source-order tie-break) */
  .nav-toggle:active {
    color: var(--color-fg);
    background-color: var(--color-kbd-bg);
    transform: scale(0.96);
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-toggle:active {
      transform: none;
    }
  }

  /* -----------------------------------------------------------------------
   * Mobile (< 48rem): nav links + language toggle collapse into the menu;
   * the bar keeps only three 44px icon buttons (search, theme, menu).
   * --------------------------------------------------------------------- */
  @media (max-width: 48rem) {
    /* Search becomes a 44px icon button, consistent with theme + menu. */
    .search-trigger {
      min-width: 0;
      min-block-size: 44px;
      min-inline-size: 44px;
      justify-content: center;
      padding: 0;
      background: transparent;
      border: none;
    }
    .search-trigger:active {
      background: var(--color-kbd-bg);
    }
    .search-placeholder,
    .search-trigger :global(.kbd) {
      display: none;
    }
    /* Language toggle leaves the bar; it reappears inside the menu. */
    .actions-lang {
      display: none;
    }

    /* JS present: nav becomes a dropdown menu toggled by the hamburger. */
    .site-header.has-js .nav-toggle {
      display: inline-flex;
    }
    .site-header.has-js .site-nav {
      /* closed state */
      display: none;
      opacity: 0;
      transform: translateY(-6px);
      position: absolute;
      top: 100%;
      inset-inline: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-2) max(var(--gutter), env(safe-area-inset-left)) var(--space-4);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
      z-index: 50;
    }
    .site-header.has-js[data-nav-open] .site-nav {
      display: flex;
      opacity: 1;
      transform: translateY(0);
    }

    /* Animation is an enhancement only: gated on motion preference. Old
       browsers / reduced-motion get the instant display:none<->flex toggle
       (today's behavior). display participates via allow-discrete; the visible
       effect lives on opacity+transform so Firefox (which animates opacity/
       transform fully but flips the display axis instantly on close) still
       fades/slides. */
    @media (prefers-reduced-motion: no-preference) {
      .site-header.has-js .site-nav {
        transition:
          opacity var(--duration-base) var(--ease-standard),
          transform var(--duration-base) var(--ease-standard),
          display var(--duration-base) var(--ease-standard) allow-discrete;
      }
      /* Seed the entry animation's "from" values; placed AFTER the rule it seeds. */
      @starting-style {
        .site-header.has-js[data-nav-open] .site-nav {
          opacity: 0;
          transform: translateY(-6px);
        }
      }
    }
    .site-nav > a {
      display: flex;
      align-items: center;
      min-block-size: 44px;
    }
    .nav-lang {
      display: flex;
      margin-top: var(--space-2);
      padding-top: var(--space-3);
      border-top: 1px solid var(--color-border-soft);
    }

    /* JS absent: keep the nav inline and reachable (the header wraps). */
    .site-header:not(.has-js) {
      flex-wrap: wrap;
    }
  }
</style>
